{
  "openapi": "3.1.1",
  "info": {
    "title": "Responses and Async API",
    "version": "1.0.0"
  },
  "paths": {
    "/jobs": {
      "post": {
        "operationId": "createJob",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NewJob"
              }
            }
          }
        },
        "responses": {
          "2XX": {
            "description": "Any successful callback response"
          },
          "201": {
            "description": "Created",
            "headers": {
              "Location": {
                "description": "Job resource URI",
                "schema": {
                  "type": "string",
                  "format": "uri"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Job"
                },
                "examples": {
                  "created": {
                    "$ref": "#/components/examples/JobCreated"
                  }
                }
              }
            },
            "links": {
              "GetCreatedJob": {
                "operationId": "getJob",
                "parameters": {
                  "jobId": "$response.body#/id"
                },
                "description": "Follow-up call to fetch the created job"
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        },
        "callbacks": {
          "jobStatus": {
            "{$request.body#/callbackUrl}": {
              "post": {
                "requestBody": {
                  "required": true,
                  "content": {
                    "application/json": {
                      "schema": {
                        "$ref": "#/components/schemas/JobEvent"
                      }
                    }
                  }
                },
                "responses": {
                  "202": {
                    "description": "Accepted by callback receiver"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/jobs/{jobId}": {
      "get": {
        "operationId": "getJob",
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Job"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "NewJob": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "callbackUrl": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "name",
          "callbackUrl"
        ]
      },
      "Job": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "status"
        ]
      },
      "JobEvent": {
        "type": "object",
        "properties": {
          "jobId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "examples": {
      "JobCreated": {
        "summary": "Created job",
        "value": {
          "id": "job_123",
          "status": "queued"
        }
      },
      "JobCreatedExternal": {
        "summary": "Externalized example",
        "externalValue": "https://example.com/examples/job-created.json"
      }
    },
    "responses": {
      "ErrorResponse": {
        "description": "Error response",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  }
}
