          "items"
        ],
        "summary": "Read item",
        "description": "Returns one item",
        "operationId": "getItem",
        "externalDocs": {
          "url": "https://example.com/docs/get-item"
        },
        "parameters": [
          {
            "name": "fields",
            "in": "query",
            "style": "form",
            "explode": false,
            "allowReserved": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "tagsPipe",
            "in": "query",
