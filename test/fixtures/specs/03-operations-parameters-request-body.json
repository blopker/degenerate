{
  "openapi": "3.1.1",
  "info": {
    "title": "Operations and Inputs API",
    "version": "1.0.0"
  },
  "paths": {
    "/items/{itemId}": {
      "summary": "Path-level summary",
      "description": "Path-level description",
      "servers": [
        {
          "url": "https://api.example.com/v1"
        }
      ],
      "parameters": [
        {
          "name": "itemId",
          "in": "path",
          "required": true,
          "description": "Item identifier",
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "X-Trace-Id",
          "in": "header",
          "required": false,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "tags": [
          "items"
        ],
        "summary": "Read item",
        "description": "Returns one item",
        "operationId": "getItem",
        "externalDocs": {
          "url": "https://example.com/docs/get-item"
        },
        "parameters": [
          {
            "name": "fields",
            "in": "query",
            "style": "form",
            "explode": false,
            "allowReserved": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "tagsPipe",
            "in": "query",
            "style": "pipeDelimited",
            "explode": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "tagsSpace",
            "in": "query",
            "style": "spaceDelimited",
            "explode": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "filter",
            "in": "query",
            "style": "deepObject",
            "explode": true,
            "schema": {
              "type": "object",
              "required": ["status", "limit"],
              "properties": {
                "status": {
                  "type": "string"
                },
                "limit": {
                  "type": "integer"
                }
              }
            }
          },
          {
            "name": "session",
            "in": "cookie",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Item found"
          }
        }
      },
      "patch": {
        "operationId": "patchItem",
        "deprecated": true,
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "photo": {
                    "type": "string",
                    "contentEncoding": "base64",
                    "contentMediaType": "image/png"
                  }
                }
              },
              "example": {
                "name": "updated",
                "photo": "iVBORw0KGgoAAAANSUhEUgAA"
              }
            },
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "avatar": {
                    "contentMediaType": "image/png"
                  }
                }
              },
              "encoding": {
                "name": {
                  "contentType": "text/plain; charset=utf-8"
                },
                "avatar": {
                  "contentType": "image/png",
                  "headers": {
                    "X-Part": {
                      "description": "Part-specific header",
                      "schema": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          }
        }
      }
    },
    "/upload": {
      "post": {
        "tags": ["items"],
        "operationId": "uploadFile",
        "summary": "Upload a file with metadata",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file", "description"],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "description": {
                    "type": "string"
                  },
                  "tags": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Uploaded"
          }
        }
      }
    },
    "/token": {
      "post": {
        "tags": ["items"],
        "operationId": "createToken",
        "summary": "Create an auth token",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["grant_type"],
                "properties": {
                  "grant_type": {
                    "type": "string"
                  },
                  "scope": {
                    "type": "string"
                  },
                  "timeout": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token created"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "items"
    }
  ]
}
